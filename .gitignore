# Firebase config now lives in .env.local (Vite convention). Firebase web API
# keys are designed to be public — they identify the project, not authenticate
# it. Real security comes from Firestore rules + the house code being known
# only to your group. Still, .env.local stays out of git as standard hygiene;
# see .env.example for the variables to fill in.
.env.local
.env*.local

# Legacy config file from the old single-HTML-file version of this app.
config.js

# Build tooling
node_modules/
dist/
dist-ssr/
*.local

