# Copy this file to .env.local and fill in your Firebase project's values.
# .env.local is gitignored — it never gets pushed to a public repo.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: live-subscription Cloudflare Worker URL (see README).
# Leave empty until you've deployed cloudflare-worker.js.
VITE_WORKER_URL=
